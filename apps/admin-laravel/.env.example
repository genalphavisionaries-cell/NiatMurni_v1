APP_NAME="Niat Murni Admin"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

GO_API_BASE_URL=http://localhost:8080
GO_API_TOKEN=dev_admin_token

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=sqlite
DB_DATABASE="database/database.sqlite"

# Supabase PostgreSQL (production / Render)
# DB_CONNECTION=pgsql
# DATABASE_URL=postgres://user:password@host:5432/database?sslmode=require
# Or: DB_HOST=... DB_PORT=5432 DB_DATABASE=niatmurni DB_USERNAME=... DB_PASSWORD=... DB_SSLMODE=require

# Stripe
STRIPE_KEY=pk_test_...
STRIPE_SECRET=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...
STRIPE_SUCCESS_URL="${APP_URL}/admin/bookings?payment=success"
STRIPE_CANCEL_URL="${APP_URL}/admin/bookings?payment=cancelled"

# Zoom (Server-to-Server OAuth)
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
